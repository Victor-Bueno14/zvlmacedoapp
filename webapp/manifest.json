{
  "_version": "1.53.0",
  "sap.app": {
    "id": "moovi.zvlmacedoapp",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:basic",
      "version": "1.20.4",
      "toolsId": "dcea5926-8b86-4357-9879-a730c86a237c"
    },
    "dataSources": {
      "mainService": {
        "uri": "/sap/opu/odata/sap/ZVLMACEDO_GW_SRV/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "localUri": "localService/mainService/metadata.xml",
          "odataVersion": "2.0"
        }
      }
    },
    "crossNavigation": {
      "inbounds": {
        "zvlmacedo_app-display": {
          "semanticObject": "zvlmacedo_app",
          "action": "display",
          "title": "{{zvlmacedo_app-display.flpTitle}}",
          "subTitle": "{{zvlmacedo_app-display.flpSubtitle}}",
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          }
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.114.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "moovi.zvlmacedoapp.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "defaultOperationMode": "Server",
          "defaultBindingMode": "TwoWay",
          "useBatch": true,
          "defaultUpdateMethod": "PUT"
        }
      },
      "editCompanyModel": {
        "type": "sap.ui.model.json.JSONModel",
        "uri": "/model/editCompany.json"
      },
      "editFlightModel": {
        "type": "sap.ui.model.json.JSONModel",
        "uri": "/model/editFlight.json"
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "viewType": "XML",
        "async": true,
        "viewPath": "moovi.zvlmacedoapp.view",
        "controlAggregation": "beginColumnPages",
        "controlId": "layout",
        "clearControlAggregation": false,
        "bypassed": {
          "target": "notFound"
        }
      },
      "routes": [
        {
          "name": "RouteList",
          "pattern": "",
          "target": [
            "TargetList"
          ]
        },
        {
          "name": "RouteObject",
          "pattern": "ScarrSet/{objectId}",
          "target": [
            "TargetList",
            "TargetObject"
          ]
        },
        {
          "name": "RouteFlight",
          "pattern": "SpfliSet/{Carrid}/{Connid}",
          "target": [
            "TargetList",
            "TargetFlight"
          ]
        }
      ],
      "targets": {
        "TargetList": {
          "viewType": "XML",
          "transition": "slide",
          "clearControlAggregation": false,
          "viewId": "List",
          "viewName": "List",
          "viewLevel": 1,
          "controlId": "layout"
        },
        "TargetObject": {
          "viewId": "detail",
          "viewName": "Detail",
          "viewLevel": 1,
          "controlAggregation": "midColumnPages",
          "clearControlAggregation": true,
          "controlId": "layout"
        },
        "TargetDetailNotFound": {
        "viewId": "detailObjectNotFound",
        "viewName": "DetailObjectNotFound",
        "controlAggregation": "midColumnPages",
        "clearControlAggregation": true,
        "controlId": "layout"
       },
       "notFound": {
         "viewId": "notFound",
         "viewName": "NotFound"
       },
       "TargetFlight": {
        "viewId": "flightDetail",
        "viewName": "FlightDetail",
        "viewLevel": 1,
        "controlAggregation": "midColumnPages",
        "clearControlAggregation": true,
        "controlId": "layout"
       }
     }
    },
    "rootView": {
      "viewName": "moovi.zvlmacedoapp.view.App",
      "type": "XML",
      "async": true,
      "id": "App"
    }
  }
}
