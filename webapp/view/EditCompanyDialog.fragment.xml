<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form">
    <Dialog 
        stretch="false"
        resizable="true"
        draggable="true"
        title="{= ${Carrid} ? ${i18n>edit_comp_title} : ${i18n>new_comp_title}}">
        <content>
            <f:SimpleForm 
                id="formEdit"
                editable="false"
                layout="ResponsiveGridLayout"
                labelSpanL="3" labelSpanM="3"
                emptySpanL="4" emptySpanM="4"
                columnsL="1" columnsM="1"
                >
                <f:content>
                    <Label text="{i18n>CompanyIDColon}" visible="{editCompanyModel>/isNew}"/>
                    <Input type="Text" visible="{editCompanyModel>/isNew}" value="{Carrid}"/>

                    <Label text="{i18n>formCompanyName}"/>
                    <Input type="Text" value="{Carrname}"/>  
                                         
                    <Label text="{i18n>formCurrCode}"/>
                    <Input type="Text" value="{Currcode}"/>

                    <Label text="{i18n>formUrl}"/>
                    <Input type="Text" value="{Url}"/> 
                </f:content>
                </f:SimpleForm>
        </content>
        <buttons>
            <Button text="{i18n>save_btn}" type="Emphasized" press=".onSaveCompanyButtonPress"/>					
			<Button text="{i18n>back_txt}" type="Default" press=".onCancelNewCompany"/>
            <Button text="{i18n>delete_txt}" type="Reject" press=".onBtnDeletePress" visible="{= !${editCompanyModel>/isNew}}" />
        </buttons>
        </Dialog>
</core:FragmentDefinition>